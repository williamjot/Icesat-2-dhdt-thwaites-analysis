             f"Afinamento : {pct_neg:.0f}%\n"
             f"Espessamento: {100-pct_neg:.0f}%",
             transform=ax2.transAxes, fontsize=10, va="top",
             bbox=dict(boxstyle="round", facecolor="white",
                       edgecolor="#AAAAAA", alpha=0.9))

    fig.suptitle(
