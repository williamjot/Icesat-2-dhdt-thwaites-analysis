    with h5py.File(out_h5, "w") as fo:
        for field in fields_float:
            arr = np.array([r[field] for r in all_results], dtype=np.float64)
            fo.create_dataset(field, data=arr,
                              compression="gzip", compression_opts=4)

        for field in fields_int:
            arr = np.array([r[field] for r in all_results], dtype=np.int32)
            fo.create_dataset(field, data=arr,
                              compression="gzip", compression_opts=4)

        beams_arr = np.array([r["beam"] for r in all_results],
                             dtype=h5py.special_dtype(vlen=str))
        fo.create_dataset("beam", data=beams_arr)

        fo.attrs["n_bins"]    = len(all_results)
        fo.attrs["t_ref"]     = T_REF
        fo.attrs["bin_size"]  = BIN_SIZE
        fo.attrs["lon_min"]   = LON_MIN
        fo.attrs["lon_max"]   = LON_MAX
        fo.attrs["lat_min"]   = LAT_MIN
        fo.attrs["lat_max"]   = LAT_MAX

    print(f"  ✓ {out_h5}")

