print("=" * 65)
print("ANÁLISE TEMPORAL POR RGT — ICESat-2 ATL06")
print("=" * 65)
print(f"  Bbox     : lon [{LON_MIN}, {LON_MAX}]  lat [{LAT_MIN}, {LAT_MAX}]")
print(f"  Período  : 2019–2025")
print(f"  Bin size : {BIN_SIZE} m")
print(f"  Min ciclos: {MIN_CYCLES}")
print(f"  T_REF    : {T_REF}")
print("=" * 65)

# ── Descobrir arquivos ATL06 ──────────────────────────────────
atl06_files = sorted(ATL06_DIR.glob("ATL06_*.h5"))
if not atl06_files:
    atl06_files = sorted(ATL06_DIR.rglob("ATL06_*.h5"))

print(f"\nArquivos ATL06 encontrados: {len(atl06_files)}")
if not atl06_files:
    raise SystemExit(f"✗ Nenhum arquivo ATL06 encontrado em {ATL06_DIR}")

# ── Estrutura de acumulação: {(rgt, beam): {cycle: dados}} ────
from collections import defaultdict
rgt_data = defaultdict(lambda: defaultdict(list))
# rgt_data[(rgt, beam)][cycle] = lista de dicts com pontos

print("\nLendo arquivos ATL06...")
for fpath in tqdm(atl06_files, desc="Arquivos"):
    for beam in BEAMS:
        seg = read_atl06_beam(fpath, beam)
        if seg is None:
            continue
        seg = filter_bbox(seg)
        if seg is None:
            continue
        seg = project_to_stereo(seg)
        key = (seg["rgt"], beam)
        rgt_data[key][seg["cycle"]].append(seg)

print(f"\n  Combinações (RGT, beam) com dados: {len(rgt_data)}")

# ── Processar cada (RGT, beam) ────────────────────────────────
all_results = []
total_figs  = 0

for (rgt, beam), cycles_dict in tqdm(rgt_data.items(),
                                      desc="RGT/Beam"):

    # Ordenar ciclos
    cycles_sorted = sorted(cycles_dict.keys())
    n_cycles      = len(cycles_sorted)

    if n_cycles < MIN_CYCLES:
        continue

    # ── Concatenar todos os ciclos numa estrutura única ───────
    # Para cada ciclo: array de pontos ordenados ao longo da trilha
    cycle_arrays = {}
    for cyc in cycles_sorted:
        segs = cycles_dict[cyc]
        # Juntar segmentos do mesmo ciclo
        x_c = np.concatenate([s["x"] for s in segs])
        y_c = np.concatenate([s["y"] for s in segs])
        h_c = np.concatenate([s["h"] for s in segs])
        s_c = np.concatenate([s["s"] for s in segs])
        t_c = np.concatenate([s["t"] for s in segs])

        # Ordenar ao longo da trilha (por latitude, sentido do satélite)
        lat_c = np.concatenate([s["lat"] for s in segs])
        order = np.argsort(lat_c)
        x_c, y_c, h_c, s_c, t_c = (x_c[order], y_c[order],
                                      h_c[order], s_c[order], t_c[order])

        # Distância ao longo da trilha
        dist_c = along_track_distance(x_c, y_c)
        bins_c = bin_along_track(dist_c, BIN_SIZE)

        cycle_arrays[cyc] = {
            "x": x_c, "y": y_c, "h": h_c, "s": s_c,
            "t": t_c, "dist": dist_c, "bins": bins_c,
        }

    # ── Descobrir todos os bins presentes ────────────────────
    all_bins = set()
    for cyc, arr in cycle_arrays.items():
        all_bins.update(arr["bins"].tolist())
    all_bins = np.array(sorted(all_bins))

    # Tempo esperado de cada ciclo (mediana dos tempos do ciclo)
    t_per_cycle = {
        cyc: float(np.median(arr["t"]))
        for cyc, arr in cycle_arrays.items()
    }
    t_cycle_vec = np.array([t_per_cycle[c] for c in cycles_sorted])

    # ── Pasta de saída para este RGT/beam ────────────────────
    fig_rgt_dir = FIG_DIR / f"rgt{rgt:04d}_{beam}"
    fig_rgt_dir.mkdir(parents=True, exist_ok=True)

    n_figs_this_rgt = 0

    # ── Loop sobre bins ──────────────────────────────────────
    for bin_id in all_bins:

        # Coletar uma observação por ciclo neste bin
        t_obs_list = []
        h_obs_list = []
        s_obs_list = []
        x0_list    = []
        y0_list    = []

        for cyc in cycles_sorted:
            arr  = cycle_arrays[cyc]
            mask = arr["bins"] == bin_id
            if mask.sum() == 0:
                continue
            # Mediana do bin neste ciclo
            t_obs_list.append(float(np.median(arr["t"][mask])))
            h_obs_list.append(float(np.median(arr["h"][mask])))
            s_obs_list.append(float(np.median(arr["s"][mask])))
            x0_list.append(float(np.median(arr["x"][mask])))
            y0_list.append(float(np.median(arr["y"][mask])))

        if len(t_obs_list) < MIN_CYCLES:
            continue

        t_obs = np.array(t_obs_list)
        h_obs = np.array(h_obs_list)
        s_obs = np.array(s_obs_list)
        x0    = float(np.mean(x0_list))
        y0    = float(np.mean(y0_list))
        lon0, lat0 = to_lonlat.transform(x0, y0)

        # ── Interpolação de ciclos faltantes ─────────────────
        h_interp = interpolate_missing_cycles(t_obs, h_obs, t_cycle_vec)

        # ── Ajuste da série temporal ──────────────────────────
        fit = fit_timeseries(t_obs, h_obs, s=s_obs)
        if fit is None:
            continue

        # ── Salvar resultado ──────────────────────────────────
        all_results.append({
            "rgt":     rgt,
            "beam":    beam,
            "bin_id":  bin_id,
            "lat":     lat0,
            "lon":     lon0,
            "x":       x0,
            "y":       y0,
            "p0":      fit["p0"],
            "p1":      fit["p1"],
            "p2":      fit["p2"],
            "p0_err":  fit["p0_err"],
            "p1_err":  fit["p1_err"],
            "p2_err":  fit["p2_err"],
            "rmse":    fit["rmse"],
            "nobs":    fit["nobs"],
            "n_interp": int(np.sum(~np.isin(
                t_cycle_vec.round(4), t_obs.round(4)
            ) & ~np.isnan(h_interp))),
        })

        # ── Plot ─────────────────────────────────────────────
        if (MAX_FIGS_PER_RGT is None or
                n_figs_this_rgt < MAX_FIGS_PER_RGT):

            out_fig = (fig_rgt_dir /
                       f"ts_rgt{rgt:04d}_{beam}_bin{bin_id:.0f}.png")
            try:
                plot_timeseries(
                    bin_id=bin_id, rgt=rgt, beam=beam,
                    lat0=lat0, lon0=lon0,
                    t_obs=t_obs, h_obs=h_obs,
                    t_all=t_cycle_vec, h_interp=h_interp,
                    fit=fit, out_path=out_fig
                )
                n_figs_this_rgt += 1
                total_figs      += 1
            except Exception as e:
                print(f"  ⚠ Erro ao plotar bin {bin_id}: {e}")

    gc.collect()

