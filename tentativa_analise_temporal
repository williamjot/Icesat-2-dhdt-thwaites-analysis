    cbar = plt.colorbar(sc, ax=ax, shrink=0.85, extend="both")
    cbar.set_label("dh/dt (m/ano)", fontsize=11)
    ax.set_xlabel("Longitude (°)", fontsize=11)
    ax.set_ylabel("Latitude (°)",  fontsize=11)
    ax.set_title("Taxa de Mudança de Elevação\nao longo dos RGTs",
                 fontsize=12, fontweight="bold")
    ax.set_aspect(1 / np.cos(np.radians(np.nanmean(lats))))
    ax.grid(True, alpha=0.3, linestyle="--")

    # Estatísticas no mapa
    info = (f"n = {len(p1s):,} bins\n"
            f"Média = {np.nanmean(p1s):+.3f} m/ano\n"
            f"Mediana = {np.nanmedian(p1s):+.3f} m/ano\n"
            f"Std = {np.nanstd(p1s):.3f} m/ano")
    ax.text(0.02, 0.97, info, transform=ax.transAxes,
            fontsize=9, va="top",
            bbox=dict(boxstyle="round", facecolor="white",
                      edgecolor="#AAAAAA", alpha=0.9))

    # ── Painel direito: histograma de dh/dt ──────────────────
    ax2 = axes[1]
    bins_hist = np.arange(-4, 2.5, 0.1)
    ax2.hist(p1s[np.isfinite(p1s)], bins=bins_hist,
             density=True, color="#CC2A2A", alpha=0.8, edgecolor="none")
    ax2.axvline(0, color="black", lw=1.5, ls="--", alpha=0.6)
