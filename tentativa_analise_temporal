# ============================================================
# PROJEÇÃO
# ============================================================
to_stereo = Transformer.from_crs("EPSG:4326", "EPSG:3031", always_xy=True)
to_lonlat = Transformer.from_crs("EPSG:3031", "EPSG:4326", always_xy=True)

# ============================================================
# FUNÇÕES AUXILIARES
# ============================================================

def mad_std(r):
    """Desvio padrão robusto via MAD."""
    med = np.nanmedian(r)
    return 1.4826 * np.nanmedian(np.abs(r - med))


def decimal_year(delta_time, atlas_epoch=2018.0):
    """
    Converte delta_time do ATL06 (segundos desde 2018-01-01) em ano decimal.
    atlas_epoch = 2018.0 (padrão ICESat-2)
    """
    return atlas_epoch + delta_time / (365.25 * 86400.0)


def read_atl06_beam(filepath, beam):
    """
    Lê um beam de um arquivo ATL06.
    Retorna dict com arrays: lat, lon, h, t, s, rgt, cycle
    ou None se o beam não existir ou estiver vazio.
    """
    try:
        with h5py.File(filepath, "r") as f:
            if beam not in f:
                return None

            grp = f[beam]["land_ice_segments"]

            lat  = grp["latitude"][:]
            lon  = grp["longitude"][:]
            h    = grp["h_li"][:]           # elevação (m)
            s    = grp["h_li_sigma"][:]     # incerteza formal (m)
            dt   = grp["delta_time"][:]     # segundos desde epoch
            atl  = f["ancillary_data"]["atlas_sdp_gps_epoch"][0]
            # epoch em ano decimal (GPS → UTC offset pequeno, ignorado aqui)
            epoch_yr = 1980.0 + atl / (365.25 * 86400.0)
            t    = decimal_year(dt, atlas_epoch=epoch_yr)

            # RGT e ciclo ficam nos metadados do arquivo
            rgt_val   = int(f["orbit_info"]["rgt"][0])
            cycle_val = int(f["orbit_info"]["cycle_number"][0])

            # Máscara de qualidade
            atl_flag = grp["atl06_quality_summary"][:]
            ok = (
                (atl_flag == 0)         &
                np.isfinite(h)          &
                np.isfinite(lat)        &
                (s > 0) & (s < 10.0)   &
                (h > -100) & (h < 5000)
            )

            if ok.sum() == 0:
                return None

            return {
                "lat":   lat[ok],
                "lon":   lon[ok],
                "h":     h[ok],
                "s":     s[ok],
                "t":     t[ok],
                "rgt":   rgt_val,
                "cycle": cycle_val,
            }

    except (OSError, KeyError):
        return None


def filter_bbox(data):
    """Filtra pontos dentro da bbox de Thwaites."""
    mask = (
        (data["lon"] >= LON_MIN) & (data["lon"] <= LON_MAX) &
        (data["lat"] >= LAT_MIN) & (data["lat"] <= LAT_MAX)
    )
    if mask.sum() == 0:
        return None
    return {k: v[mask] if isinstance(v, np.ndarray) else v
            for k, v in data.items()}


def project_to_stereo(data):
    """Adiciona colunas x, y (EPSG:3031) ao dict."""
    x, y = to_stereo.transform(data["lon"], data["lat"])
    data["x"] = x
    data["y"] = y
    return data


def along_track_distance(x, y):
    """
    Distância acumulada ao longo da trilha (metros).
    Assume que os pontos já estão ordenados ao longo do perfil.
    """
    dx = np.diff(x)
    dy = np.diff(y)
    ds = np.sqrt(dx**2 + dy**2)
    return np.concatenate([[0.0], np.cumsum(ds)])


def bin_along_track(s_dist, bin_size):
    """Atribui cada ponto a um bin de `bin_size` metros."""
    return (np.floor(s_dist / bin_size) * bin_size).astype(np.float64)


def interpolate_missing_cycles(t_obs, h_obs, t_all_cycles):
    """
    Interpola valores faltantes usando vizinhos temporais mais próximos.
    t_obs      : tempos com observações
    h_obs      : elevações observadas
    t_all_cycles: todos os tempos esperados (um por ciclo)
    Retorna h_interp para todos os ciclos, com NaN onde não há cobertura.
    """
    if len(t_obs) < 2:
        return np.full(len(t_all_cycles), np.nan)

    # Interpolação linear com extrapolação NaN fora do intervalo
    f = interp1d(t_obs, h_obs, kind="linear",
                 bounds_error=False, fill_value=np.nan)
    return f(t_all_cycles)


def fit_timeseries(t, h, s=None):
    """
    Ajusta h(t) = p0 + p1·Δt + p2·½Δt² com rejeição iterativa de outliers.
    Retorna dict com p0, p1, p2, erros, rmse, nobs ou None se falhar.
    """
    dt = t - T_REF
    n  = len(dt)
    if n < MIN_CYCLES:
        return None
    if (t.max() - t.min()) < DT_MIN:
        return None

    A = np.column_stack([np.ones(n), dt, 0.5 * dt**2])
    m = A.shape[1]

    mask = np.ones(n, dtype=bool)
    xhat = ehat = None
    rmse = np.nan

    for _ in range(5):
        Af = A[mask]
        hf = h[mask]
        nf = mask.sum()
        if nf < m + 2:
            return None

        if s is not None:
            sf  = s[mask]
            sf  = np.where(sf <= 0, np.median(sf[sf > 0]) if (sf > 0).any() else 0.05, sf)
            wf  = 1.0 / (sf**2 + 1e-12)
            wf /= wf.mean()
            W   = np.sqrt(wf)
            Aw  = Af * W[:, None]
            hw  = hf * W
        else:
            Aw, hw = Af, hf

        try:
            xhat_new, _, rank, _ = linalg.lstsq(Aw, hw, check_finite=False)
        except (linalg.LinAlgError, ValueError):
            return None

        if rank < m:
            return None

        xhat = xhat_new
        res  = hf - Af @ xhat
        rmse = float(np.std(res))

        try:
            sig2 = float(np.sum(res**2) / max(nf - m, 1))
            ehat = np.sqrt(np.abs(np.diag(linalg.inv(Aw.T @ Aw))) * sig2)
        except linalg.LinAlgError:
            ehat = np.full(m, np.nan)

        mad = mad_std(res)
        if mad < 1e-10:
            break
        bad = np.abs(res) > N_SIGMA * mad
        if not bad.any():
            break
        mask[np.where(mask)[0][bad]] = False

    if xhat is None:
        return None

    p1 = float(xhat[1])
    p2 = float(xhat[2])

    if abs(p1) > RATE_LIM:
        return None
    if abs(p2) > P2_LIM:
        p2 = np.nan
        ehat[2] = np.nan

    return {
        "p0":     float(xhat[0]),
        "p1":     p1,
        "p2":     p2,
        "p0_err": float(ehat[0]) if ehat is not None else np.nan,
        "p1_err": float(ehat[1]) if ehat is not None else np.nan,
        "p2_err": float(ehat[2]) if ehat is not None else np.nan,
        "rmse":   rmse,
        "nobs":   int(mask.sum()),
        "mask":   mask,
    }


# ============================================================
# FUNÇÃO DE PLOT — série temporal de um bin
# ============================================================

def plot_timeseries(bin_id, rgt, beam, lat0, lon0,
                    t_obs, h_obs, t_all, h_interp,
                    fit, out_path):
    """
    Gráfico completo da série temporal de um bin:
      - Pontos observados
      - Valores interpolados (ciclos faltantes)
      - Curva ajustada
      - Resíduos
      - Metadados do ajuste
    """
    fig = plt.figure(figsize=(13, 8))
    gs  = gridspec.GridSpec(3, 1, height_ratios=[3, 1.2, 0.05],
                            hspace=0.12)

    ax1 = fig.add_subplot(gs[0])
    ax2 = fig.add_subplot(gs[1], sharex=ax1)

    # ── Série temporal ──────────────────────────────────────
    # Pontos observados (usados no ajuste)
    mask_fit = fit["mask"]
    t_fit = t_obs[mask_fit]
    h_fit = h_obs[mask_fit]

    # Pontos rejeitados
    t_rej = t_obs[~mask_fit]
    h_rej = h_obs[~mask_fit]

    # Pontos interpolados (ciclos faltantes)
    t_missing = t_all[~np.isin(t_all.round(4),
                                t_obs.round(4))]
    h_missing = h_interp[~np.isin(t_all.round(4),
                                   t_obs.round(4))]
    valid_interp = ~np.isnan(h_missing)

    # Curva ajustada
    t_curve = np.linspace(t_all.min(), t_all.max(), 300)
    dt_c    = t_curve - T_REF
    h_curve = (fit["p0"]
               + fit["p1"] * dt_c
               + (0.5 * fit["p2"] * dt_c**2
                  if not np.isnan(fit["p2"]) else 0.0))

    # Banda de incerteza (±1σ do p1 propagada)
    h_upper = h_curve + fit["p1_err"] * np.abs(dt_c)
    h_lower = h_curve - fit["p1_err"] * np.abs(dt_c)

    ax1.fill_between(t_curve, h_lower, h_upper,
                     alpha=0.15, color="#1565C0", label="±1σ (p1)")
    ax1.plot(t_curve, h_curve, "-", color="#1565C0",
             lw=2.0, label="Ajuste polinomial", zorder=5)

    if valid_interp.any():
        ax1.plot(t_missing[valid_interp], h_missing[valid_interp],
                 "s", color="#FF9800", ms=7, alpha=0.7,
                 label=f"Interpolado ({valid_interp.sum()} ciclos)", zorder=3)

    ax1.plot(t_fit, h_fit, "o", color="#2E7D32", ms=6,
             label=f"Observado ({len(t_fit)} ciclos)", zorder=4)

    if len(t_rej) > 0:
        ax1.plot(t_rej, h_rej, "x", color="red", ms=8,
                 mew=2, label=f"Rejeitado ({len(t_rej)})", zorder=4)

    ax1.set_ylabel("Elevação h (m)", fontsize=11)
    ax1.legend(fontsize=9, loc="best", framealpha=0.9)
    ax1.grid(True, alpha=0.3, linestyle="--")
    ax1.tick_params(labelbottom=False)

    # Anotação com resultados
    p2_str = (f"{fit['p2']:+.4f} ± {fit['p2_err']:.4f} m/ano²"
              if not np.isnan(fit["p2"]) else "n/d")
    info = (
        f"dh/dt  = {fit['p1']:+.4f} ± {fit['p1_err']:.4f} m/ano\n"
        f"d²h/dt²= {p2_str}\n"
        f"h₀     = {fit['p0']:.2f} m  (ref. {T_REF})\n"
        f"RMSE   = {fit['rmse']:.4f} m   |   n = {fit['nobs']} ciclos"
    )
    ax1.text(0.02, 0.97, info, transform=ax1.transAxes,
             fontsize=9.5, va="top", fontfamily="monospace",
             bbox=dict(boxstyle="round,pad=0.5", facecolor="white",
                       edgecolor="#AAAAAA", alpha=0.92))

    # ── Resíduos ─────────────────────────────────────────────
    if len(t_fit) > 0:
        h_pred_fit = (fit["p0"]
                      + fit["p1"] * (t_fit - T_REF)
                      + (0.5 * fit["p2"] * (t_fit - T_REF)**2
                         if not np.isnan(fit["p2"]) else 0.0))
        res = h_fit - h_pred_fit
        ax2.bar(t_fit, res, width=0.06, color="#2E7D32",
                alpha=0.7, label="Resíduos")
        ax2.axhline(0, color="black", lw=1.0, ls="--")
        ax2.axhline( fit["rmse"], color="gray", lw=0.8, ls=":")
        ax2.axhline(-fit["rmse"], color="gray", lw=0.8, ls=":")
        ax2.set_ylabel("Resíduo (m)", fontsize=10)
        ax2.set_xlabel("Ano", fontsize=11)
        ax2.grid(True, alpha=0.3, linestyle="--")

    # ── Título ───────────────────────────────────────────────
    taxa_cor = "#CC2A2A" if fit["p1"] < 0 else "#1565C0"
    taxa_txt = f"dh/dt = {fit['p1']:+.3f} m/ano"
    fig.suptitle(
        f"Série Temporal ICESat-2 — RGT {rgt:04d} | {beam.upper()} | "
        f"Bin {bin_id:.0f} m\n"
        f"Lat {lat0:.4f}°  Lon {lon0:.4f}°  |  "
        f"{taxa_txt}",
        fontsize=11, fontweight="bold", color=taxa_cor
    )

    plt.tight_layout(rect=[0, 0, 1, 0.95])
    plt.savefig(out_path, dpi=150, bbox_inches="tight", facecolor="white")
    plt.close(fig)


