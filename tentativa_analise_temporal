# Bounding box de Thwaites (graus decimais)
LON_MIN, LON_MAX = -106.5, -103.5
LAT_MIN, LAT_MAX = -75.5,  -74.5

# Ano de referência (centro do período)
T_REF = 2022.5

# Tamanho do bin ao longo da trilha (metros)
# 500 m → resolução compatível com ATL06 (segmentos de ~20 m agrupados)
BIN_SIZE = 500.0

# Raio de busca dentro do bin para agrupar medições (metros)
# Um bin de 500 m pode ter pequenos desvios laterais entre ciclos
BIN_HALF = BIN_SIZE / 2.0

# Mínimo de ciclos válidos para ajustar a série
MIN_CYCLES = 6

# Span temporal mínimo (anos)
DT_MIN = 2.0

# Limiar de rejeição de outliers (n-sigma)
N_SIGMA = 3.0

# Limite físico de dh/dt para Thwaites
RATE_LIM = 8.0   # m/ano

# Limite de aceleração
P2_LIM = 1.0     # m/ano²

# Máximo de figuras a gerar por RGT (None = todos)
# Coloque um número pequeno (ex: 10) para testar rapidamente
MAX_FIGS_PER_RGT = 10

# Beams ATL06 a processar (gt1l, gt1r, gt2l, gt2r, gt3l, gt3r)
